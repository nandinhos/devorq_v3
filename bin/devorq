#!/usr/bin/env bash
# bin/devorq — DEVORQ v3.7 CLI (Modularizado)
#
# Uso:
#   devorq <comando> [args...]
#
# Comandos principais:
#   init, foundation, flow, gate, lessons, context, compact, vps
#   skills, version, info, upgrade, test, sync, debug, stats
#   scope, ddd, env, spec, unify, mode, auto, review

# shellcheck disable=SC1091,SC2086,SC2034,SC2015,SC2001,SC2162,SC1090,SC1010,SC2164,SC2155,SC2094,SC2005,SC2317,SC2129,SC2126,SC2120,SC2119,SC2116,SC2046

# ============================================================
# BOOTSTRAP
# ============================================================

readonly DEVORQ_ROOT="${DEVORQ_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
readonly DEVORQ_LIB="${DEVORQ_ROOT}/lib"
readonly DEVORQ_BIN="${DEVORQ_ROOT}/bin"
readonly DEVORQ_VERSION="3.7.0"

# Load libraries
source "${DEVORQ_LIB}/helpers.sh"
source "${DEVORQ_LIB}/visual.sh"
source "${DEVORQ_LIB}/gates.sh"
source "${DEVORQ_LIB}/context.sh"
source "${DEVORQ_LIB}/lessons.sh"

# ============================================================
# HELP
# ============================================================

devorq::help() {
    cat << 'HELPEOF'
DEVORQ v3.7 — Framework de Desenvolvimento Sistemático

Uso: devorq <comando> [args...]

Comandos:
  init          Inicializar projeto (.devorq/)
  foundation    Criar 5W2H, Premissas, Riscos, Requisitos, Restrições
  flow          Executar workflow completo (gates 0→7)
  gate [N]      Executar gate específico (0-7)
  
  lessons       Gerenciar lições aprendidas
    capture     Capturar nova lição
    list        Listar lições
    search      Buscar lições
    validate    Validar lições (Context7)
    approve     Aprovar lição
    compile     Compilar lições em skills
  
  context       Gerenciar contexto do projeto
    get         Mostrar contexto atual
    set         Definir campo do contexto
    merge       Mesclar contextos
  
  compact       Gerar handoff (compact)
  vps           Gerenciar conexão VPS
  sync          Sincronizar com HUB/VPS
  skills        Listar skills disponíveis
  
  ddd           Domain-Driven Design
    explore     Explorar domínio
    validate    Validar SPEC.md
  scope         Verificar escopo do projeto
  unify         Unificar artefatos
  mode          Selecionar modo (AUTO/CLASSIC)
  auto          Executar modo AUTO (story-by-story)
  
  info          Informações do sistema
  stats         Estatísticas de uso
  version       Versão do DEVORQ
  upgrade       Atualizar DEVORQ
  test          Executar testes
  
  debug         Debug sistemático
  review        Code review

Use: devorq help <comando> para ajuda específica
HELPEOF
}

# ============================================================
# MAIN DISPATCH
# ============================================================

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        init)           source "${DEVORQ_LIB}/commands/workflow.sh" && devorq::cmd_init "$@" ;;
        foundation)     source "${DEVORQ_LIB}/commands/foundation.sh" && devorq::cmd_foundation "$@" ;;
        flow)           source "${DEVORQ_LIB}/commands/workflow.sh" && devorq::cmd_flow "$@" ;;
        gate)           source "${DEVORQ_LIB}/commands/workflow.sh" && devorq::cmd_gate "$@" ;;
        
        lessons)
            local action="${1:-}"
            shift || true
            # Check if action is --help and delegate to lessons::help
            if [[ "$action" == "--help" ]] || [[ "$action" == "-h" ]]; then
                lessons::help
                return 0
            fi
            # Handle --help for subcommands
            if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
                lessons::help
                return 0
            fi
            case "$action" in
                capture)  lessons::capture "${1:-}" "${2:-}" "${3:-}" ;;
                list)     lessons::list "${1:-}" ;;
                search)   lessons::search "${1:-}" ;;
                validate) lessons::validate "${1:-}" ;;
                approve)  lessons::approve "${1:-}" "${2:-}" "${3:-}" ;;
                compile)  lessons::compile "${1:-}" "${2:-}" "${3:-}" ;;
                migrate)  lessons::migrate ;;
                help|--help|-h) lessons::help ;;
                *)        lessons::help ;;
            esac
            ;;
        
        context)
            local action="${1:-}"
            case "$action" in
                get)   ctx_get ;;
                set)   ctx_set "${2:-}" "${3:-}" ;;
                merge) ctx_merge "${2:-}" ;;
                clear) ctx_clear ;;
                stats) ctx_stats ;;
                *)     echo "Uso: devorq context <get|set|merge|clear|stats>" ;;
            esac
            ;;
        
        compact)    source "${DEVORQ_LIB}/commands/context.sh" && devorq::cmd_compact ;;
        vps)        source "${DEVORQ_LIB}/commands/integration.sh" && devorq::cmd_vps "$@" ;;
        sync)       source "${DEVORQ_LIB}/commands/integration.sh" && devorq::cmd_sync "$@" ;;
        
        skills)     source "${DEVORQ_LIB}/commands/skills.sh" && devorq::cmd_skills ;;
        
        ddd)
            local action="${1:-}"
            case "$action" in
                validate)  source "${DEVORQ_LIB}/commands/ddd.sh" && devorq::cmd_ddd_validate ;;
                explore)   source "${DEVORQ_LIB}/commands/ddd.sh" && devorq::cmd_ddd_explore ;;
                *) echo "Uso: devorq ddd <validate|explore>" ;;
            esac
            ;;
        
        scope)      source "${DEVORQ_LIB}/commands/exploration.sh" && devorq::cmd_scope "$@" ;;
        env)
            local action="${1:-detect}"
            shift || true
            source "${DEVORQ_LIB}/commands/exploration.sh" && devorq::cmd_env "$action" "$@"
            ;;
        spec)       source "${DEVORQ_LIB}/commands/exploration.sh" && devorq::cmd_spec "$@" ;;
        unify)      source "${DEVORQ_LIB}/commands/exploration.sh" && devorq::cmd_unify "$@" ;;
        mode)       source "${DEVORQ_LIB}/commands/mode.sh" && devorq::cmd_mode "$@" ;;
        auto)       source "${DEVORQ_LIB}/commands/auto.sh" && devorq::cmd_auto "$@" ;;
        review)     source "${DEVORQ_LIB}/commands/review.sh" && devorq::cmd_review "$@" ;;
        build)      source "${DEVORQ_LIB}/commands/utils.sh" && devorq::cmd_build ;;
        stats)      source "${DEVORQ_LIB}/commands/utils.sh" && devorq::cmd_stats ;;
        
        version)    echo "DEVORQ v${DEVORQ_VERSION}" ;;
        info)       source "${DEVORQ_LIB}/commands/info.sh" && devorq::cmd_info ;;
        upgrade)    source "${DEVORQ_LIB}/commands/utils.sh" && devorq::cmd_upgrade ;;
        test)       source "${DEVORQ_LIB}/commands/test.sh" && devorq::cmd_test ;;
        debug)      source "${DEVORQ_LIB}/commands/debug.sh" && devorq::cmd_debug "$@" ;;
        
        uninstall)  source "${DEVORQ_LIB}/commands/utils.sh" && devorq::cmd_uninstall ;;
        
        help|--help|-h) devorq::help ;;
        
        *) 
            if [[ -n "$cmd" ]]; then
                echo "[ERROR] Comando desconhecido: $cmd" >&2
                echo "Use 'devorq help' para ajuda"
                return $EXIT_INVALID_ARGS
            fi
            devorq::help
            ;;
    esac
}

main "$@"
