#!/usr/bin/env bash
# bin/devorq — DEVORQ v3.2 CLI
#
# LOCALINSTALL: Este repo é ~/.devorq/ (global)
# PROJETO: .devorq/ no projeto (só config/state)
#
# Uso:
#   devorq init                    Inicializar projeto
#   devorq test                   Testar estrutura
#   devorq gate [1-7]             Executar gate
#   devorq lessons capture       Capturar lição
#   devorq lessons search "<q>"  Buscar lições
#   devorq lessons validate       Validar com Context7
#   devorq context                Mostrar contexto atual
#   devorq compact                Gerar handoff
#   devorq sync push|pull         Sincronizar com HUB
#   devorq vps check              Testar conexão VPS
#   devorq version                Versão
#   devorq upgrade                Atualizar
#   devorq uninstall              Remover

set -euo pipefail

# ============================================================
# BOOTSTRAP
# ============================================================

DEVORQ_ROOT="${DEVORQ_ROOT:-$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)}"
DEVORQ_LIB="${DEVORQ_ROOT}/lib"
DEVORQ_VERSION="3.2.1"

# jq no ~/bin (instalado via curl sem root)
if [ -d "${HOME}/bin" ] && [[ ":$PATH:" != *":${HOME}/bin:"* ]]; then
    export PATH="${HOME}/bin:$PATH"
fi

# ============================================================
# LOGGING (sem cores — compatibilidade máxima)
# ============================================================

devorq::log()   { echo "[DEVORQ] $*"; }
devorq::info()  { echo "[DEVORQ] $*"; }
devorq::success() { echo "[OK] $*"; }
devorq::warn()  { echo "[!] $*"; }
devorq::error() { echo "[ERROR] $*" >&2; exit 1; }
devorq::fail() { echo "[FAIL] $*"; }

# ============================================================
# HELP
# ============================================================

devorq::help() {
    cat << EOF
DEVORQ v${DEVORQ_VERSION} — Framework bash puro para metodologia de desenvolvimento sistemático

USO:
  devorq <comando> [opções]

COMANDOS:
  init                       Inicializar .devorq/ no projeto
  test                       Testar estrutura do projeto
  flow "<intent>"           Workflow completo (gates 1-7)
  gate [1-7]                Executar gate específico

  lessons capture "<t>" "<p>" "<s>"
                             Capturar lição aprendida
  lessons search "<q>"      Buscar lições locais
  lessons validate           Validar lição com Context7

  context                    Mostrar contexto atual
  compact                    Gerar handoff para próxima sessão
  scope validate <f>        Validar contrato de escopo
  scope template             Mostrar template de contrato
  ddd explore                Workshop interativo de domínio
  ddd validate               Validar SPEC.md (GATE-0)

  sync push                  Enviar lessons → HUB
  sync pull                  Receber lessons ← HUB
  vps check                  Testar conexão com VPS HUB
  context7 install           Instalar Context7 (cli|mcp|api)
  debug [erro]               Workflow debug sistemático (4 fases)
  build                      Executa devorq test + gates 1-7 (Self-Building)
  stats                      Mostra estatísticas de uso (lessons, gates, contexto)

  version                    Versão instalada
  upgrade                    Atualizar DEVORQ
  uninstall                  Remover instalação global

OPÇÕES:
  -h, --help                Este help
  -v, --verbose             Modo debug

EXEMPLOS:
  devorq init
  devorq test
  devorq gate 1
  devorq lessons capture "jq install" "no apt-get" "curl binary to ~/bin"
  devorq vps check

EOF
}

# ============================================================
# COMMANDS
# ============================================================

devorq::cmd_init() {
    # Cria .devorq/ no projeto atual (não em ~/.devorq/)
    local project_root="${PWD}"
    local devorq_dir="${project_root}/.devorq"

    if [ -d "$devorq_dir" ]; then
        devorq::warn "Já existe .devorq/ em ${project_root}"
        return 0
    fi

    mkdir -p "$devorq_dir/state/lessons/captured"
    mkdir -p "$devorq_dir/skills"
    mkdir -p "$devorq_dir/rules"

    # Copiar templates do global se existirem
    if [ -f "${DEVORQ_ROOT}/.devorq/commit_convention.json" ]; then
        cp "${DEVORQ_ROOT}/.devorq/commit_convention.json" "$devorq_dir/"
    fi

    cat > "$devorq_dir/state/context.json" << 'EOFC'
{
  "project": "",
  "stack": [],
  "intent": "",
  "gates_completed": [],
  "last_updated": ""
}
EOFC

    cat > "$devorq_dir/state/session.json" << 'EOFS'
{
  "started_at": "",
  "ended_at": "",
  "handoff_id": null,
  "summary": ""
}
EOFS

    devorq::success "Inicializado .devorq/ em ${project_root}"
    devorq::info "Edite .devorq/state/context.json com project, stack e intent"
}

devorq::cmd_flow() {
    local intent="${1:-}"
    [ -z "$intent" ] && devorq::error "Uso: devorq flow \"<intent>\""

    devorq::log "Intent: ${intent}"
    devorq::log "Executando gates 1-7..."

    local failed=0
    for gate in 1 2 3 4 5 6 7; do
        devorq::info "--- GATE ${gate} ---"
        # Sem || aqui — set -e do gates.sh não propaga pro caller
        if ! devorq::cmd_gate "$gate" 2>&1; then
            devorq::error "Gate ${gate} falhou"
        fi
    done

    devorq::success "Flow completo!"
}

devorq::cmd_gate() {
    local gate_num="${1:-}"
    local lib_gate="${DEVORQ_LIB}/gates.sh"

    if [ ! -f "$lib_gate" ]; then
        devorq::warn "lib/gates.sh não encontrado — gate simulado"
        devorq::info "GATE-${gate_num}: (sem lib/gates.sh — implementar)"
        return 0
    fi

    source "$lib_gate"
    # Captura exit code explicitamente — evita conflito com set -e
    "gate_${gate_num}"; local rv=$?
    return $rv
}

devorq::cmd_lessons() {
    local sub="$1"
    local lib_lessons="${DEVORQ_LIB}/lessons.sh"

    case "$sub" in
        capture)
            local title="${2:-}"
            local problem="${3:-}"
            local solution="${4:-}"
            [ -z "$title" ] && devorq::error "Uso: devorq lessons capture \"<t>\" \"<p>\" \"<s>\""
            if [ ! -f "$lib_lessons" ]; then
                devorq::warn "lib/lessons.sh não encontrado — criando stub"
                devorq::info "LESSON: title=${title}"
                return 0
            fi
            source "$lib_lessons"
            lessons::capture "$title" "$problem" "$solution"
            ;;
        search)
            local query="${2:-}"
            [ -z "$query" ] && devorq::error "Uso: devorq lessons search \"<query>\""
            source "${DEVORQ_LIB}/lessons.sh" 2>/dev/null || true
            lessons::search "$query"
            ;;
        validate)
            source "${DEVORQ_LIB}/lessons.sh" 2>/dev/null || true
            lessons::validate || devorq::info "LESSONS validate: (lib não disponível)"
            ;;
        *)
            devorq::error "Uso: devorq lessons capture|search|validate"
            ;;
    esac
}

devorq::cmd_context() {
    local ctx_file="${PWD}/.devorq/state/context.json"
    local sub="${1:-}"

    source "${DEVORQ_LIB}/context.sh" 2>/dev/null || {
        # Fallback: apenas mostra arquivo
        if [ ! -f "$ctx_file" ]; then
            devorq::warn "Nenhum .devorq/state/context.json encontrado"
            devorq::info "Execute 'devorq init' primeiro"
            return 0
        fi
        cat "$ctx_file"
        return 0
    }

    case "$sub" in
        lint)   ctx_lint ;;
        stats)  ctx_stats ;;
        pack)   ctx_pack "${2:-}" ;;
        merge)  ctx_merge "${2:-}" "${3:-}" ;;
        set)    ctx_set "${2:-}" "${3:-}" ;;
        clear)  ctx_clear ;;
        "")
            # Default: mostra stats e contexto
            if [ ! -f "$ctx_file" ]; then
                devorq::warn "Nenhum context.json encontrado — iniciando contexto"
                ctx_set "project" "${PWD##*/}"
                ctx_set "stack" "[]"
                ctx_set "intent" ""
            fi
            ctx_stats
            echo ""
            cat "$ctx_file"
            ;;
        *)       echo "Uso: devorq context [lint|stats|pack|merge|set|clear]"; return 1 ;;
    esac
}

devorq::cmd_compact() {
    devorq::info "Gerando contexto compactado para handoff..."
    source "${DEVORQ_LIB}/compact.sh" 2>/dev/null || true
    compact::generate 2>/dev/null || {
        devorq::warn "lib/compact.sh não disponível — usando contexto direto"
        cat "${PWD}/.devorq/state/context.json" 2>/dev/null || echo "{}"
    }
}

devorq::cmd_vps() {
    local sub="${1:-check}"
    case "$sub" in
        check)
            source "${DEVORQ_LIB}/vps.sh" 2>/dev/null || true
            vps::check 2>/dev/null || devorq::info "VPS check: (lib não disponível)"
            ;;
        *)
            devorq::error "Uso: devorq vps check"
            ;;
    esac
}

devorq::cmd_context7() {
    local sub="${1:-help}"
    case "$sub" in
        install)
            source "${DEVORQ_LIB}/context7.sh" 2>/dev/null || true
            if declare -f ctx7_install &>/dev/null; then
                ctx7_install "${2:-}"
            else
                devorq::error "lib/context7.sh não disponível"
            fi
            ;;
        detect)
            source "${DEVORQ_LIB}/context7.sh" 2>/dev/null || true
            if declare -f ctx7_detect &>/dev/null; then
                local method; method=$(ctx7_detect)
                devorq::info "Método disponível: $method"
            else
                devorq::error "lib/context7.sh não disponível"
            fi
            ;;
        check)
            source "${DEVORQ_LIB}/context7.sh" 2>/dev/null || true
            if declare -f ctx7_check &>/dev/null; then
                ctx7_check
            else
                devorq::error "lib/context7.sh não disponível"
            fi
            ;;
        help|--help|-h|"")
            devorq::info "Uso: devorq context7 install|detect|check"
            devorq::info "  install    Instalar Context7 (cli|mcp|api)"
            devorq::info "  detect     Detectar método disponível"
            devorq::info "  check      Testar Context7"
            ;;
        *)
            devorq::error "Uso: devorq context7 install|detect|check"
            ;;
    esac
}

devorq::cmd_skills() {
    local sub="${1:-list}"
    case "$sub" in
        list)
            devorq::info "Skills disponíveis: systemic-debugging, github-code-review, github-pr-workflow, plan, subagent-driven-development, test-driven-development"
            devorq::info "Use 'devorq skills load <name>' no Hermes Agent para carregar"
            ;;
        load)
            local name="${2:-}"
            [ -z "$name" ] && devorq::error "Uso: devorq skills load <name>"
            devorq::info "Skills são carregadas via Hermes Agent — não diretamente via CLI bash"
            ;;
        *)
            devorq::error "Uso: devorq skills list|load <name>"
            ;;
    esac
}

devorq::cmd_version() {
    echo "DEVORQ v${DEVORQ_VERSION}"
}

devorq::cmd_upgrade() {
    devorq::info "Atualizando DEVORQ..."
    local current_version
    current_version=$(cat "${DEVORQ_ROOT}/.devorq/version" 2>/dev/null || echo "desconhecida")
    devorq::info "Versão atual: $current_version"

    if [ -d "${DEVORQ_ROOT}/.git" ]; then
        git -C "${DEVORQ_ROOT}" pull || devorq::error "Git pull falhou"
        local new_version
        new_version=$(cat "${DEVORQ_ROOT}/.devorq/version" 2>/dev/null || echo "desconhecida")
        devorq::success "Atualizado: $current_version -> $new_version"

        # Re-roda build para confirmar integridade
        devorq::info "Executando devorq build para validar..."
        devorq::cmd_build
    else
        devorq::error "Não é um clone git — use install.sh"
    fi
}

devorq::cmd_test() {
    devorq::info "Testando estrutura..."
    local errors=0

    # Testa sintaxe
    bash -n "${DEVORQ_ROOT}/bin/devorq" 2>/dev/null || { devorq::warn "bin/devorq: syntax error"; errors=$((errors+1)); }
    for f in "${DEVORQ_LIB}"/*.sh; do
        bash -n "$f" 2>/dev/null || { devorq::warn "$f: syntax error"; errors=$((errors+1)); }
    done

    # Testa libs que existem
    [ -f "${DEVORQ_LIB}/lessons.sh" ] || { devorq::warn "lib/lessons.sh: not found"; errors=$((errors+1)); }
    [ -f "${DEVORQ_LIB}/gates.sh" ] || { devorq::warn "lib/gates.sh: not found"; errors=$((errors+1)); }
    [ -f "${DEVORQ_LIB}/compact.sh" ] || { devorq::warn "lib/compact.sh: not found"; errors=$((errors+1)); }
    [ -f "${DEVORQ_LIB}/vps.sh" ] || { devorq::warn "lib/vps.sh: not found"; errors=$((errors+1)); }

    if [ $errors -eq 0 ]; then
        devorq::success "Estrutura OK (devorq v${DEVORQ_VERSION})"
    else
        devorq::error "$errors erro(s) encontrado(s)"
    fi
}

devorq::cmd_sync() {
    local sub="${1:-}"
    case "$sub" in
        push)
            devorq::info "Sincronizando lessons para HUB..."
            export DEVORQ_PROJECT_ROOT="${PWD}"
            if [ -f "${DEVORQ_ROOT}/scripts/sync-push.py" ]; then
                python3 "${DEVORQ_ROOT}/scripts/sync-push.py" 2>&1 || devorq::warn "sync push: falha"
            else
                devorq::warn "scripts/sync-push.py não encontrado"
            fi
            ;;
        pull)
            devorq::info "Sincronizando lessons do HUB..."
            export DEVORQ_PROJECT_ROOT="${PWD}"
            if [ -f "${DEVORQ_ROOT}/scripts/sync-pull.py" ]; then
                python3 "${DEVORQ_ROOT}/scripts/sync-pull.py" 2>&1 || devorq::warn "sync pull: falha"
            else
                devorq::warn "scripts/sync-pull.py não encontrado"
            fi
            ;;
        *)
            devorq::error "Uso: devorq sync push|pull"
            ;;
    esac
}

devorq::cmd_uninstall() {
    devorq::warn "Remover DEVORQ de ${DEVORQ_ROOT}?"
    devorq::info "Ctrl+C para cancelar, Enter para confirmar"
    read -r

    # Preserva .devorq/ (versão e config do framework — não remove)
    if [ -d "${DEVORQ_ROOT}/.devorq" ]; then
        devorq::info "Preservando .devorq/ (version, config)..."
    fi

    rm -rf "${DEVORQ_ROOT}"
    devorq::success "Removido de ${DEVORQ_ROOT}"
    devorq::info "Execute 'rm -f ~/bin/devorq' para remover o symlink"
}

devorq::cmd_debug() {
    source "${DEVORQ_LIB}/debug.sh" 2>/dev/null || true
    if declare -f devorq::debug &>/dev/null; then
        devorq::debug "${1:-}"
    else
        devorq::warn "lib/debug.sh não disponível"
    fi
}

devorq::cmd_build() {
    devorq::info "═══ DEVORQ Self-Build ═══"
    devorq::info "Executando teste + gates 1-7 no repositório DEVORQ..."
    echo ""

    # Self-build sempre opera no repo DEVORQ, não no projeto atual
    local original_pwd="$PWD"
    cd "${DEVORQ_ROOT}"

    # Etapa 1: teste de estrutura
    devorq::info "── Etapa 1: devorq test ──"
    if ! devorq::cmd_test; then
        devorq::warn "devorq test falhou"
    fi
    echo ""

    # Etapa 2: todos os gates
    local failed=0
    for gate in 1 2 3 4 5 6 7; do
        devorq::info "── Etapa 2: Gate $gate ──"
        if ! devorq::cmd_gate "$gate"; then
            devorq::fail "Gate $gate falhou"
            ((failed++))
        fi
    done

    cd "$original_pwd"

    echo ""
    devorq::info "═══ Resultado ═══"
    if [ $failed -eq 0 ]; then
        devorq::success "Build OK — 7/7 gates verdes"
        devorq::info "Sistema pronto para self-building"
        return 0
    else
        devorq::error "$failed gate(s) falhou(aram)"
    fi
}

devorq::cmd_stats() {
    # Stats sempre opera no repo DEVORQ (como build)
    local original_pwd="$PWD"
    cd "${DEVORQ_ROOT}"

    source "${DEVORQ_LIB}/stats.sh" 2>/dev/null || true
    if declare -f stats::summary &>/dev/null; then
        stats::summary
    else
        devorq::warn "lib/stats.sh não disponível"
    fi

    cd "$original_pwd"
}

devorq::cmd_scope() {
    local sub="${1:-}"
    local scope_root="${DEVORQ_ROOT}/skills/scope-guard"

    case "$sub" in
        validate)
            local contract="${2:-}"
            [ -z "$contract" ] && devorq::error "Uso: devorq scope validate <arquivo.md>"
            local validator="${scope_root}/scripts/scope-validate.sh"
            if [ ! -f "$validator" ]; then
                devorq::error "scope-validate.sh não encontrado"
            fi
            if bash "$validator" "$contract"; then
                devorq::success "Contrato válido"
                return 0
            else
                devorq::fail "Contrato incompleto"
                return 1
            fi
            ;;
        template)
            devorq::info "Template de contrato de escopo:"
            echo ""
            cat << 'EOF'
# CONTRATO DE ESCOPO — [nome-da-task]

## IDENTIFICAÇÃO
- **Task**: [resumo]
- **Tipo**: feature | bugfix | refactor
- **Complexidade**: baixa | média | alta

## FAZER
1. [funcionalidade específica]

## NÃO FAZER
1. [o que NÃO fazer]

## ARQUIVOS
- `caminho/arquivo.ext`

## DONE_CRITERIA
- [ ] [critério verificável]
EOF
            ;;
        *)
            devorq::info "Scope-Guard — Contrato de Escopo"
            echo ""
            devorq::info "Use: devorq scope validate <arquivo.md>"
            devorq::info "     devorq scope template"
            ;;
    esac
}

devorq::cmd_ddd() {
    local sub="${1:-}"
    local ddd_root="${DEVORQ_ROOT}/skills/ddd-deep-domain"

    case "$sub" in
        explore)
            devorq::info "DDD Domain Workshop — pressione Ctrl+C para sair"
            echo ""
            devorq::info "Carregue a skill: hermes load ddd-deep-domain"
            devorq::info "Ou leia: ${ddd_root}/SKILL.md"
            echo ""
            devorq::info "Referências: ${ddd_root}/references/domain-questions.md"
            devorq::info "Validador:  ${ddd_root}/scripts/ddd-validate-spec.sh"
            ;;
        validate)
            local validator="${ddd_root}/scripts/ddd-validate-spec.sh"
            if [ ! -f "$validator" ]; then
                devorq::error "ddd-validate-spec.sh não encontrado"
            fi
            if bash "$validator"; then
                devorq::success "SPEC.md tem modelo mental válido"
                return 0
            else
                devorq::fail "SPEC.md não tem alma (entidades, contextos, invariantes)"
                return 1
            fi
            ;;
        *)
            devorq::error "Uso: devorq ddd explore|validate"
            ;;
    esac
}

# ============================================================
# MAIN DISPATCH
# ============================================================

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        -h|--help) devorq::help ;;
        -v|--verbose) set -x; shift; main "$@" ;;
        init)      shift; devorq::cmd_init "$@" ;;
        test)      devorq::cmd_test ;;
        flow)      shift; devorq::cmd_flow "$@" ;;
        gate)      shift; devorq::cmd_gate "$@" ;;
        lessons)   shift; devorq::cmd_lessons "$@" ;;
        context)   devorq::cmd_context ;;
        compact)   devorq::cmd_compact ;;
        scope)     shift; devorq::cmd_scope "$@" ;;
        ddd)       shift; devorq::cmd_ddd "$@" ;;
        sync)      shift; devorq::cmd_sync "$@" ;;
        vps)       shift; devorq::cmd_vps "$@" ;;
        context7)  shift; devorq::cmd_context7 "$@" ;;
        skills)    shift; devorq::cmd_skills "$@" ;;
        debug)     devorq::cmd_debug "$@" ;;
        build)     devorq::cmd_build ;;
        stats)     devorq::cmd_stats ;;
        version)   devorq::cmd_version ;;
        upgrade)   devorq::cmd_upgrade ;;
        uninstall) devorq::cmd_uninstall ;;
        *)         devorq::help ;;
    esac
}

main "$@"
