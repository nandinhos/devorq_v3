# extras with credentials
.devorq/extras/sync_config.json

# Dependencies
node_modules/
/package.json
/package-lock.json
# e2e-tests/package-lock.json é versionado (necessario p/ npm ci + cache no CI — DQ-026)

# Session summaries (ephemeral)
.devorq/state/sessions/

# Snapshot files — generated per-command, never commit
.devorq/state/pre_tool_snapshot.json
.devorq/.devorq/state/pre_tool_snapshot.json

# Nested .devorq directory (artifact from init, not real structure)
.devorq/.devorq/

# Build artifacts
*.log
.DS_Store
.devorq/state/lessons/downloaded/

# Claude Code config (não commitado)
.claude/

# UNIFY state (gerado por devorq unify, não versionado)
.devorq/state/unify/

# IDE
.vscode/
.idea/
.cursor/

# Backups
bin/devorq.backup*

# Testes E2E
e2e-tests/playwright-report/
e2e-tests/test-results/
e2e-tests/*.log
e2e-tests/playwright.config.ts.tmp

# Skills geradas (não versionar)
skills/learned-lesson/

# Docs temporários
docs/PLANO_CORRECAO*.md
docs/REFATORACAO*.md
.opencode/
test_hook_*

# Python bytecode
__pycache__/
*.pyc
