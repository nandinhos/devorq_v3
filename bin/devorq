#!/usr/bin/env bash
# bin/devorq -- DEVORQ vVERSION CLI Router
#
# Uso:
#   devorq <comando> [args...]
#
# Comandos principais:
#   init, foundation, mode, test
#   flow, gate, auto, ddd, scope, env, spec, grill, brainstorm
#   lessons, context, compact, unify, debug
#   commit, vps, sync, context7, rules, review, version, upgrade, build, uninstall, stats
#   skills, info
#
# Este arquivo e apenas o ROUTER. Toda a logica vive em lib/dispatchers/*.sh

set -euo pipefail

# shellcheck disable=SC1091,SC2086,SC2034,SC2015,SC2001,SC2162,SC1090,SC1010,SC2164,SC2155,SC2094,SC2005,SC2317,SC2129,SC2126,SC2120,SC2119,SC2116,SC2046

# ============================================================
# BOOTSTRAP
# ============================================================

readonly DEVORQ_ROOT="${DEVORQ_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
readonly DEVORQ_LIB="${DEVORQ_ROOT}/lib"
readonly DEVORQ_BIN="${DEVORQ_ROOT}/bin"
readonly DEVORQ_VERSION="VERSION"
readonly DEVORQ_DISPATCHERS_DIR="${DEVORQ_LIB}/dispatchers"

# Carrega bibliotecas core (mantem ordem para dependencias)
# shellcheck source=lib/helpers.sh
source "${DEVORQ_LIB}/helpers.sh"
# shellcheck source=lib/visual.sh
source "${DEVORQ_LIB}/visual.sh"
# shellcheck source=lib/gates.sh
source "${DEVORQ_LIB}/gates.sh"
# shellcheck source=lib/context.sh
source "${DEVORQ_LIB}/context.sh"
# shellcheck source=lib/lessons.sh
source "${DEVORQ_LIB}/lessons.sh"

# Carrega dispatchers (dynamic source loop)
# Cada dispatcher agrupa comandos por afinidade e expoe devorq::cmd_*
if [[ -d "${DEVORQ_DISPATCHERS_DIR}" ]]; then
    for _dispatcher in "${DEVORQ_DISPATCHERS_DIR}"/*.sh; do
        [[ -f "$_dispatcher" ]] || continue
        # shellcheck disable=SC1090
        source "$_dispatcher"
    done
    unset _dispatcher
else
    echo "[ERROR] dispatchers dir nao encontrado: ${DEVORQ_DISPATCHERS_DIR}" >&2
    exit 1
fi

# ============================================================
# HELP
# ============================================================

devorq::help() {
    cat << 'HELPEOF'
DEVORQ v3.8.5 — Framework de Desenvolvimento Sistemático

Uso: devorq <comando> [args...]

Comandos:
  init          Inicializar projeto (.devorq/)
  foundation    Criar 5W2H, Premissas, Riscos, Requisitos, Restrições
  flow          Executar workflow completo (gates 0→7)
  gate [N]      Executar gate específico (0-7)
  
  lessons       Gerenciar lições aprendidas
    capture     Capturar nova lição
    list        Listar lições
    search      Buscar lições
    validate    Validar lições (Context7)
    approve     Aprovar lição
    compile     Compilar lições em skills
  
  context       Gerenciar contexto do projeto
    get         Mostrar contexto atual
    set         Definir campo do contexto
    merge       Mesclar contextos
  
  compact       Gerar handoff (compact)
  vps           Gerenciar conexão VPS
  sync          Sincronizar com HUB/VPS
  skills        Listar skills disponíveis
  
  ddd           Domain-Driven Design
    explore     Explorar domínio
    validate    Validar SPEC.md
  scope         Verificar escopo do projeto
  unify         Unificar artefatos
  mode          Selecionar modo (AUTO/CLASSIC)
  auto          Executar modo AUTO (story-by-story)
  commit        Commit manual com convenção escopo(fase):
  verify        Verificação visual / E2E antes do commit
  rules         Regras enforced (list, check, apply, bootstrap)
  
  info          Informações do sistema
  stats         Estatísticas de uso
  version       Versão do DEVORQ
  upgrade       Atualizar DEVORQ
  test          Executar testes
  
  debug         Debug sistemático
  review        Code review

Use: devorq help <comando> para ajuda específica
HELPEOF
}

# ============================================================
# MAIN DISPATCH (router puro)
# ============================================================

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        # INIT dispatcher
        init)        devorq::cmd_init "$@" ;;
        foundation)  devorq::cmd_foundation "$@" ;;
        mode)        devorq::cmd_mode "$@" ;;
        test)        devorq::cmd_test "$@" ;;

        # WORKFLOW dispatcher
        flow)        devorq::cmd_flow "$@" ;;
        gate)        devorq::cmd_gate "$@" ;;
        auto)        devorq::cmd_auto "$@" ;;
        ddd)         devorq::cmd_ddd "$@" ;;
        scope)       devorq::cmd_scope "$@" ;;
        env)         devorq::cmd_env "$@" ;;
        spec)        devorq::cmd_spec "$@" ;;
        grill)       devorq::cmd_grill "$@" ;;
        brainstorm)  devorq::cmd_brainstorm "$@" ;;

        # STATE dispatcher
        lessons)     devorq::cmd_lessons "$@" ;;
        context)     devorq::cmd_context "$@" ;;
        compact)     devorq::cmd_compact "$@" ;;
        unify)       devorq::cmd_unify "$@" ;;
        debug)       devorq::cmd_debug "$@" ;;

        # DELIVERY dispatcher
        commit)      devorq::cmd_commit_dispatch "$@" ;;
        vps)         devorq::cmd_vps "$@" ;;
        sync)        devorq::cmd_sync "$@" ;;
        context7)    devorq::cmd_context7 "$@" ;;
        rules)       devorq::cmd_rules_dispatch "$@" ;;
        review)      devorq::cmd_review "$@" ;;
        upgrade)     devorq::cmd_upgrade "$@" ;;
        build)       devorq::cmd_build "$@" ;;
        uninstall)   devorq::cmd_uninstall "$@" ;;
        stats)       devorq::cmd_stats "$@" ;;

        # DISCOVERY dispatcher
        skills)      devorq::cmd_skills "$@" ;;
        info)        devorq::cmd_info "$@" ;;

        # Built-in (sem dispatcher dedicado)
        version)     echo "DEVORQ v${DEVORQ_VERSION}" ;;
        verify)      devorq::cmd_verify "$@" ;;

        help|--help|-h) devorq::help ;;

        *)
            if [[ -n "$cmd" ]]; then
                echo "[ERROR] Comando desconhecido: $cmd" >&2
                echo "Use devorq help para ajuda" >&2
                return 1
            fi
            devorq::help
            ;;
    esac
}

main "$@"
