#!/usr/bin/env bash
# bin/devorq — DEVORQ v3.2 CLI
#
# LOCALINSTALL: Este repo é ~/.devorq/ (global)
# PROJETO: .devorq/ no projeto (só config/state)
#
# Uso:
#   devorq init                    Inicializar projeto
#   devorq flow "<intent>"         Workflow completo
#   devorq gate [1-7]              Executar gate
#   devorq lessons capture "<t>" "<p>" "<s>"  Capturar lição
#   devorq lessons search "<q>"    Buscar lições
#   devorq lessons validate       Validar com Context7
#   devorq context                 Mostrar contexto atual
#   devorq compact                 Gerar handoff
#   devorq vps check               Testar conexão VPS
#   devorq version                 Versão
#   devorq upgrade                 Atualizar
#   devorq uninstall               Remover

set -euo pipefail

# ============================================================
# BOOTSTRAP — descobrir onde está o ~/.devorq/
# ============================================================

# Se este script está em ~/.devorq/bin/devorq
DEVORQ_ROOT="${DEVORQ_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

# Garantir que lib/ está no PATH de sourcing
DEVORQ_LIB="${DEVORQ_ROOT}/lib"
DEVORQ_VERSION=$(cat "${DEVORQ_ROOT}/.devorq/version" 2>/dev/null || echo "unknown")

# jq no ~/bin (instalado via curl sem root)
if [ -d "${HOME}/bin" ] && [[ ":$PATH:" != *":${HOME}/bin:"* ]]; then
    export PATH="${HOME}/bin:$PATH"
fi

# ============================================================
# COLORS
# ============================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# ============================================================
# LOGGING
# ============================================================

devorq::log() { echo -e "${CYAN}[DEVORQ]${RESET} $*"; }
devorq::info() { echo -e "${CYAN}[DEVORQ]${RESET} $*"; }
devorq::success() { echo -e "${GREEN}[✓]${RESET} $*"; }
devorq::warn() { echo -e "${YELLOW}[!]${RESET} $*"; }
devorq::error() { echo -e "${RED}[✗]${RESET} $*" >&2; exit 1; }

# ============================================================
# HELP
# ============================================================

devorq::help() {
    cat << EOF
${BOLD}DEVORQ v${DEVORQ_VERSION}${RESET} — Framework Agêntico de Desenvolvimento

${BOLD}USO:${RESET}
  devorq <comando> [opções]

${BOLD}COMANDOS:${RESET}
  init                       Inicializar .devorq/ no projeto
  flow "<intent>"           Workflow completo (gates 1-7)
  gate [1-7]                Executar gate específico

  lessons capture "<t>" "<p>" "<s>"
                             Capturar lição aprendida
  lessons search "<q>"       Buscar lições no HUB
  lessons validate          Validar lição com Context7

  context                   Mostrar contexto atual
  compact                   Gerar handoff para próxima sessão

  vps check                 Testar conexão com VPS HUB
  skills list              Listar skills disponíveis
  skills load <name>        Carregar skill na sessão

  version                   Versão instalada
  upgrade                   Atualizar DEVORQ
  uninstall                 Remover instalação global

${BOLD}OPÇÕES:${RESET}
  -h, --help                Este help
  -v, --verbose             Modo debug
  -y, --yes                 Confirmar tudo (não-interativo)

${BOLD}EXEMPLOS:${RESET}
  devorq init
  devorq flow "criar API de usuários"
  devorq gate 3
  devorq lessons capture "use jq not python" "json" "bash"
  devorq vps check

EOF
}

# ============================================================
# COMMANDS
# ============================================================

devorq::cmd_init() {
    # Cria .devorq/ no projeto atual (não em ~/.devorq/)
    local project_root="${PWD}"
    local devorq_dir="${project_root}/.devorq"

    if [ -d "$devorq_dir" ]; then
        devorq::warn "Já existe .devorq/ em ${project_root}"
        return 0
    fi

    mkdir -p "$devorq_dir/state"
    mkdir -p "$devorq_dir/skills"
    mkdir -p "$devorq_dir/rules"

    # Copiar templates do global se existirem
    if [ -f "${DEVORQ_ROOT}/.devorq/commit_convention.json" ]; then
        cp "${DEVORQ_ROOT}/.devorq/commit_convention.json" "$devorq_dir/"
    fi

    cat > "$devorq_dir/state/context.json" << 'EOF'
{
  "project": "",
  "stack": [],
  "intent": "",
  "session": "",
  "gates_completed": [],
  "last_updated": ""
}
EOF

    devorq::success "Inicializado .devorq/ em ${project_root}"
    devorq::info "Edite .devorq/state/context.json com project, stack e intent"
}

devorq::cmd_flow() {
    local intent="${1:-}"
    [ -z "$intent" ] && devorq::error "Uso: devorq flow \"<intent>\""

    devorq::log "Intent: ${intent}"
    devorq::log "Executando gates 1-7..."

    for gate in 1 2 3 4 5 6 7; do
        devorq::info "--- GATE ${gate} ---"
        devorq::cmd_gate "$gate" || devorq::error "Gate ${gate} falhou"
    done

    devorq::success "Flow completo!"
}

devorq::cmd_gate() {
    local gate_num="${1:-}"
    local lib_gate="${DEVORQ_LIB}/gates.sh"

    if [ ! -f "$lib_gate" ]; then
        devorq::warn "lib/gates.sh não encontrado — gate simulado"
        devorq::info "GATE-${gate_num}: (sem lib/gates.sh — implementar)"
        return 0
    fi

    source "$lib_gate"
    "gate_${gate_num}"
}

devorq::cmd_lessons() {
    local sub="$1"
    local lib_lessons="${DEVORQ_LIB}/lessons.sh"

    case "$sub" in
        capture)
            local title="${2:-}"
            local problem="${3:-}"
            local solution="${4:-}"
            [ -z "$title" ] && devorq::error "Uso: devorq lessons capture \"<t>\" \"<p>\" \"<s>\""
            if [ ! -f "$lib_lessons" ]; then
                devorq::warn "lib/lessons.sh não encontrado — criando stub"
                devorq::info "LESSON: title=${title}"
                return 0
            fi
            source "$lib_lessons"
            lessons::capture "$title" "$problem" "$solution"
            ;;
        search)
            local query="${2:-}"
            [ -z "$query" ] && devorq::error "Uso: devorq lessons search \"<query>\""
            source "${DEVORQ_LIB}/lessons.sh" 2>/dev/null || true
            lessons::search "$query"
            ;;
        validate)
            source "${DEVORQ_LIB}/lessons.sh" 2>/dev/null || true
            lessons::validate || devorq::info "LESSONS validate: (lib não disponível)"
            ;;
        *)
            devorq::error "Uso: devorq lessons capture|search|validate"
            ;;
    esac
}

devorq::cmd_context() {
    local ctx_file="${PWD}/.devorq/state/context.json"
    if [ ! -f "$ctx_file" ]; then
        devorq::warn "Nenhum .devorq/state/context.json encontrado"
        devorq::info "Execute 'devorq init' primeiro"
        return 0
    fi
    cat "$ctx_file"
}

devorq::cmd_compact() {
    devorq::info "Gerando contexto compactado para handoff..."
    source "${DEVORQ_LIB}/compact.sh" 2>/dev/null || true
    compact::generate 2>/dev/null || {
        devorq::warn "lib/compact.sh não disponível — usando contexto direto"
        cat "${PWD}/.devorq/state/context.json" 2>/dev/null || echo "{}"
    }
}

devorq::cmd_vps() {
    local sub="${1:-check}"
    case "$sub" in
        check)
            source "${DEVORQ_LIB}/vps.sh" 2>/dev/null || true
            vps::check 2>/dev/null || devorq::info "VPS check: (lib não disponível)"
            ;;
        *)
            devorq::error "Uso: devorq vps check"
            ;;
    esac
}

devorq::cmd_skills() {
    local sub="${1:-list}"
    case "$sub" in
        list)
            devorq::info "Skills disponíveis:"
            ls "${DEVORQ_ROOT}/.devorq/skills/" 2>/dev/null | while read s; do
                echo "  - $s"
            done || echo "  (nenhuma skill global)"
            ;;
        load)
            local name="${2:-}"
            [ -z "$name" ] && devorq::error "Uso: devorq skills load <name>"
            skill_view "$name" 2>/dev/null || devorq::error "Skill '$name' não encontrada"
            ;;
        *)
            devorq::error "Uso: devorq skills list|load <name>"
            ;;
    esac
}

devorq::cmd_version() {
    echo "DEVORQ v${DEVORQ_VERSION}"
}

devorq::cmd_upgrade() {
    devorq::info "Atualizando DEVORQ..."
    if [ -d "${DEVORQ_ROOT}/.git" ]; then
        git -C "${DEVORQ_ROOT}" pull || devorq::error "Git pull falhou"
        devorq::success "Atualizado para $(cat "${DEVORQ_ROOT}/.devorq/version")"
    else
        devorq::error "Não é um clone git — use install.sh"
    fi
}

devorq::cmd_uninstall() {
    devorq::warn "Remover DEVORQ de ${DEVORQ_ROOT}?"
    devorq::info "Ctrl+C para cancelar, Enter para confirmar"
    read -r
    rm -rf "${DEVORQ_ROOT}"
    devorq::success "Removido de ${DEVORQ_ROOT}"
}

# ============================================================
# MAIN DISPATCH
# ============================================================

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        -h|--help) devorq::help ;;
        -v|--verbose) set -x; shift; main "$@" ;;
        -y|--yes) export DEVORQ_YES=1; shift; main "$@" ;;
        init)      shift; devorq::cmd_init "$@" ;;
        flow)      shift; devorq::cmd_flow "$@" ;;
        gate)      shift; devorq::cmd_gate "$@" ;;
        lessons)   shift; devorq::cmd_lessons "$@" ;;
        context)   devorq::cmd_context ;;
        compact)   devorq::cmd_compact ;;
        vps)       shift; devorq::cmd_vps "$@" ;;
        skills)    shift; devorq::cmd_skills "$@" ;;
        version)   devorq::cmd_version ;;
        upgrade)   devorq::cmd_upgrade ;;
        uninstall) devorq::cmd_uninstall ;;
        *)         devorq::help ;;
    esac
}

main "$@"
