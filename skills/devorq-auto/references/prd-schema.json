{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "devorq-auto prd.json",
  "description": "Schema para arquivos prd.json gerados pelo devorq-auto (padrao Ralph-style)",
  "type": "object",
  "required": ["project", "created", "stories"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Nome do projeto ( basename do diretorio )"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO 8601 da criacao do prd.json"
    },
    "stories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "acceptanceCriteria", "priority", "passes"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+-[0-9]+$",
            "description": "ID unico da story, ex: feat-001, fix-001, refactor-001"
          },
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "Titulo curto e descritivo da story"
          },
          "description": {
            "type": "string",
            "description": "Descricao expandida do que implementar"
          },
          "acceptanceCriteria": {
            "type": "array",
            "minItems": 1,
            "description": "Lista de criterios verificaveis (CHECK = done)",
            "items": { "type": "string" }
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "description": "Ordem de execucao (1 = primeiro)"
          },
          "passes": {
            "type": "boolean",
            "description": "true quando verificada e commitada"
          },
          "notes": {
            "type": "string",
            "description": "Notas opcionais de implementacao"
          }
        }
      }
    }
  }
}
